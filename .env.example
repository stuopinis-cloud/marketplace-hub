APP_NAME="Marketplace Hub"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=marketplace_hub
DB_USERNAME=marketplace_hub
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=marketplace_hub_

MEMCACHED_HOST=127.0.0.1

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Integrations (configure per environment)
# ---------------------------------------------------------------------------

# Shopify (use your myshopify.com domain, not the public storefront domain)
SHOPIFY_SHOP=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_API_VERSION=2026-01
SHOPIFY_PRODUCT_PAGE_SIZE=20
SHOPIFY_VARIANT_PAGE_SIZE=50
SHOPIFY_MEDIA_PAGE_SIZE=5
SHOPIFY_INVENTORY_LEVEL_PAGE_SIZE=1
SHOPIFY_COLLECTION_PAGE_SIZE=20

# Marketplace exports
VARLE_DEFAULT_DELIVERY_TEXT="1-2 d.d."
VARLE_FEED_PATH=feeds/varle.xml
VARLE_EXPORT_CHUNK_SIZE=100
VARLE_VAT_RATE=21
APP_STORE_URL=https://ebunkeris.lt

# Entirem API (Helikon / Direct-Action supplier stock)
ENTIREM_API_TOKEN=

# Prezioso CSV feed (NTLM)
PREZIOSO_NTLM_USERNAME=
PREZIOSO_NTLM_PASSWORD=

# Sync job health
SYNC_STUCK_AFTER_MINUTES=10

# Daily marketplace sync (Shopify import, suppliers, readiness, Varle export)
MARKETPLACE_DAILY_SYNC_ENABLED=true
MARKETPLACE_DAILY_SYNC_TIME=03:00

# eBay / translations
EBAY_EXPORT_LOCALE=en
EBAY_EXPORT_CURRENCY=EUR
EBAY_FEED_PATH=feeds/ebay-en.xml
EBAY_TITLE_MAX_LENGTH=80
EBAY_EXPORT_REQUIRES_APPROVED_TRANSLATIONS=false
AUTO_QUEUE_MISSING_TRANSLATIONS_FOR_EBAY=false
MARKETPLACE_TRANSLATION_PROVIDER=openai
MARKETPLACE_TRANSLATION_SOURCE_LOCALE=lt
OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=gpt-4o-mini
