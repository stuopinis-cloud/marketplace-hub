APP_NAME="Marketplace Hub"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://hub.gudle.lt

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=marketplace_hub
DB_USERNAME=marketplace_hub
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@ebunkeris.lt"
MAIL_FROM_NAME="${APP_NAME}"

# Shopify
SHOPIFY_SHOP=c88j71-wn.myshopify.com
SHOPIFY_API_VERSION=2026-01
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_PRODUCT_PAGE_SIZE=20
SHOPIFY_VARIANT_PAGE_SIZE=50
SHOPIFY_MEDIA_PAGE_SIZE=5
SHOPIFY_INVENTORY_LEVEL_PAGE_SIZE=1
SHOPIFY_COLLECTION_PAGE_SIZE=20

# Marketplace exports
VARLE_DEFAULT_DELIVERY_TEXT="1-2 d.d."
VARLE_FEED_PATH=feeds/varle.xml
VARLE_FEED_PUBLIC_URL=https://hub.gudle.lt/feeds/varle.xml
VARLE_EXPORT_CHUNK_SIZE=100
VARLE_VAT_RATE=21
APP_STORE_URL=https://ebunkeris.lt
